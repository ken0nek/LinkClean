default_platform(:ios)

XCODEPROJ = "LinkClean.xcodeproj".freeze
SCHEME = "LinkClean".freeze
APP_TARGETS = ["LinkClean", "LinkCleanAction", "LinkCleanMarkdownAction", "LinkCleanWidgetExtension"].freeze
EXTENSION_TARGETS = (APP_TARGETS - [SCHEME]).freeze

platform :ios do
  desc "Bump version number (type: major|minor|patch, or version: X.Y.Z)"
  lane :bump_version do |options|
    if options[:version]
      APP_TARGETS.each do |target|
        increment_version_number_in_xcodeproj(
          xcodeproj: XCODEPROJ,
          version_number: options[:version],
          target: target
        )
      end
    else
      increment_version_number_in_xcodeproj(
        xcodeproj: XCODEPROJ,
        bump_type: options[:type] || "patch",
        target: SCHEME
      )
      app_version = get_version_number_from_xcodeproj(
        xcodeproj: XCODEPROJ,
        target: SCHEME
      )
      EXTENSION_TARGETS.each do |target|
        increment_version_number_in_xcodeproj(
          xcodeproj: XCODEPROJ,
          version_number: app_version,
          target: target
        )
      end
    end
  end

  desc "Bump build number (number: N, or auto-increments by 1)"
  lane :bump_build do |options|
    if options[:number]
      APP_TARGETS.each do |target|
        increment_build_number_in_xcodeproj(
          xcodeproj: XCODEPROJ,
          build_number: options[:number].to_s,
          target: target
        )
      end
    else
      increment_build_number_in_xcodeproj(
        xcodeproj: XCODEPROJ,
        target: SCHEME
      )
      build_number = get_build_number_from_xcodeproj(
        xcodeproj: XCODEPROJ,
        target: SCHEME
      )
      EXTENSION_TARGETS.each do |target|
        increment_build_number_in_xcodeproj(
          xcodeproj: XCODEPROJ,
          build_number: build_number,
          target: target
        )
      end
    end
  end

  desc "Bump both version and build number"
  lane :bump do |options|
    bump_version(type: options[:type], version: options[:version])
    bump_build(number: options[:number])
  end

  desc "Build IPA for App Store distribution"
  lane :build do
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      clean: true,
      export_method: "app-store"
    )
  end

  desc "Bump build, build IPA, and upload to TestFlight (changelog: 'What to test')"
  lane :beta do |options|
    bump_build(number: options[:number])
    build
    upload_to_testflight(
      changelog: options[:changelog],
      skip_waiting_for_build_processing: true,
      distribute_external: true,
      groups: ["dogfooding"]
    )
  end

  desc "Bump, build, and submit to App Store"
  lane :release do |options|
    bump(type: options[:type], version: options[:version], number: options[:number])
    build
    upload_to_app_store(
      skip_screenshots: true,
      skip_metadata: options.fetch(:skip_metadata, false),
      submit_for_review: options[:submit] || false,
      automatic_release: options[:auto_release].nil? ? true : options[:auto_release],
      force: true
    )
  end

  desc "Build and submit to App Store WITHOUT bumping (reuses the current version + build)"
  lane :submit do |options|
    build
    upload_to_app_store(
      skip_screenshots: true,
      skip_metadata: options.fetch(:skip_metadata, false),
      submit_for_review: options[:submit] || false,
      automatic_release: options[:auto_release].nil? ? true : options[:auto_release],
      force: true
    )
  end

  # Reads composited PNGs from fastlane/screenshots/{locale}/{device}_*.png
  # (produced by the LinkCleanScreenshots scheme — see
  # docs/release/app-store-metadata.md). Composite outputs
  # before running this lane; nothing here builds them.
  desc "Upload screenshots only (no binary, no metadata)"
  lane :screenshots do
    app_version = get_version_number_from_xcodeproj(
      xcodeproj: XCODEPROJ,
      target: SCHEME
    )
    upload_to_app_store(
      app_version: app_version,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end

  desc "Upload metadata only (no binary, no screenshots)"
  lane :metadata do
    app_version = get_version_number_from_xcodeproj(
      xcodeproj: XCODEPROJ,
      target: SCHEME
    )
    upload_to_app_store(
      app_version: app_version,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: false,
      force: true
    )
  end
end
