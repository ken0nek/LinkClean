        "baseFilters": "thisApp",
        "granularity": "day",
        "filter": {
          "type": "or",
          "fields": [
            { "type": "selector", "dimension": "type", "value": "Home.URL.cleaned" },
            { "type": "selector", "dimension": "type", "value": "Action.Clean.succeeded" },
            { "type": "selector", "dimension": "type", "value": "Intent.Clean.succeeded" },
            { "type": "selector", "dimension": "type", "value": "QR.Scan.succeeded" }
