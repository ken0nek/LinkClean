      },
      {
        "type": "event",
        "name": "Intent.Clean.failed",
        "hint": "App Intent ran but produced no clean — clipboard tapped with nothing usable, or a Shortcuts input that wasn't a web URL. The annoyance read (insight 6). Carries `intentSurface` + `reason` (noURL / invalidInput)."
      },
      {
        "type": "event",
        "name": "QR.Scan.succeeded",
        "hint": "A scanned QR contained a web link and was cleaned. The scan funnel base (insight 7). Carries the full clean Telemetry incl. `unwrapped` + `domain`."
      },
      {
        "type": "event",
        "name": "QR.Scan.failed",
        "hint": "Scan produced nothing usable. Carries `reason` (noLink = decoded but not a web URL; unreadable = no QR found in the picked image)."
      },
      {
        "type": "event",
        "name": "QR.Result.actioned",
        "hint": "An export off the QR result sheet (the funnel's payoff). Carries `action` (copy / share / open). Scan→action conversion is insight 7."
      },
      {
        "type": "event",
        "name": "QR.Code.generated",
        "hint": "The generate-half: a QR image rendered from a cleaned link and shared. Carries `changed`."
      },
      {
        "type": "event",
        "name": "Stats.Screen.shown",
        "hint": "Statistics dashboard appeared. Carries `hasData` — separates arrivals at a populated dashboard from the empty state. A high empty-state share means the entry point surfaces too early (V3 growth-loop roadmap §5)."
      },
      {
        "type": "event",
        "name": "Stats.Card.shared",
        "hint": "The privacy share card was shared — the #1 organic-growth lever (memory roadmap §11). Carries `entryPoint` (toolbar / cta). Insight 12 is the viral north-star; insight 13 is the affordance split."
      },
      {
        "type": "event",
        "name": "Settings.TextFragments.toggled",
        "hint": "The scroll-to-text fragment (`:~:`) removal setting was toggled. Default-on: heavy `enabled=false` = users want it off (E2)."
      },
      {
        "type": "event",
        "name": "Settings.QRButton.toggled",
        "hint": "The 'Share as QR Code' Home-button setting was toggled. Default-off: heavy `enabled=true` = the QR button has Home-real-estate demand."
      },
      {
        "type": "event",
        "name": "Parameters.Advisor.suggested",
        "hint": "The unknown-parameter advisor surfaced a leftover (at most one per clean). Carries `tier` (reference / heuristic / model) — the deterministic-floor-vs-on-device-model split that says whether the model earns its battery (ai-A)."
      },
      {
        "type": "event",
        "name": "Parameters.Advisor.accepted",
        "hint": "User tapped Always Remove on a suggestion (the accept signal — fires whether or not the add is then gated by Pro). Carries `tier`. The funnel numerator vs `suggested` (insight 15)."
      },
      {
        "type": "event",
        "name": "Parameters.Advisor.dismissed",
        "hint": "User tapped Not Now on a suggestion. Carries `tier`. Dispatch mix vs `accepted` = the §9-A value read (insight 16)."
      },
      {
        "type": "parameter",
        "name": "unwrapped",
        "hint": "Bool on every clean event — `true` iff the cleaner peeled at least one redirect wrapper (E1). The unwrap-rate numerator (insight 1)."
      },
      {
        "type": "parameter",
        "name": "intentSurface",
        "hint": "Logical App Intents surface — shortcut (CleanLinkIntent — Shortcuts/Siri/Spotlight/Action button) or clipboard (CleanClipboardIntent — incl. Control Center + widget). Distinct from the `surface` default param (process — app/action/copyAction/intent)."
      },
      {
        "type": "parameter",
        "name": "tier",
        "hint": "On Advisor events: which stage produced the suggestion (reference = bundled-catalog hit; heuristic = name-shape rule; model = on-device Foundation Models verdict). Also the default `tier` param on every signal (free/pro) — slice any insight here by free vs pro for the behavioral read."
      },
      {
        "type": "parameter",
        "name": "hasData",
        "hint": "Bool — did the Stats screen open onto data (true) or the empty state (false). Separates first-time-discoverers from the V3 share-card funnel base."
      },
      {
        "type": "parameter",
        "name": "entryPoint",
        "hint": "Which V3 affordance shared the privacy card: toolbar (the nav-bar share icon) or cta (the prominent foot-of-dashboard button). Sent under `entryPoint`, never `surface` (which is the process default param)."
      },
      {
        "type": "parameter",
        "name": "preset",
        "hint": "Bool on Action.Format.succeeded — true if a shipped preset rendered, false if a user-authored custom template. A custom-leaning mix is the strongest signal that Pro customization will sell."
      },
      {
        "type": "parameter",
        "name": "action",
        "hint": "On QR.Result.actioned: copy / share / open — which export path the user took off the scan result sheet."
      },
      {
        "type": "parameter",
        "name": "reason",
        "hint": "Failure detail on QR.Scan.failed (noLink / unreadable) and Intent.Clean.failed (noURL / invalidInput)."
      },
      {
        "type": "parameter",
        "name": "enabled",
        "hint": "Toggle state when a Settings.*.toggled event fired. true / false."
      },
      {
        "type": "parameter",
        "name": "surface",
        "hint": "Process default parameter on every signal: app / action / copyAction / intent. Set in TelemetryDeckAnalytics.start; intent-process work startIfNeeded's it because widget/control-center may run in a fresh process."
      }
    ]
  }
}
