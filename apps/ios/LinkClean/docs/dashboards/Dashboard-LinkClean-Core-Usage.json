      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 0,
      "customQuery": {
        "queryType": "timeseries",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "day",
        "filter": {
          "type": "selector",
          "dimension": "type",
          "value": "TelemetryDeck.Acquisition.newInstallDetected"
        },
        "aggregations": [
          {
            "type": "longSum",
            "name": "installs",
            "fieldName": "count"
          }
        ]
      }
    },
