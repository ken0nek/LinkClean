    {
      "title": "Activation — installs that reached a first export (lifetime proxy, all surfaces)",
      "type": "customQuery",
      "displayMode": "bigNumber",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 3,
      "customQuery": {
        "queryType": "timeseries",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "all",
        "filter": {
          "type": "or",
          "fields": [
            { "type": "selector", "dimension": "type", "value": "Home.URL.copied" },
            { "type": "selector", "dimension": "type", "value": "Home.URL.shared" },
            { "type": "selector", "dimension": "type", "value": "Action.Clean.succeeded" },
            { "type": "selector", "dimension": "type", "value": "Action.Format.succeeded" },
            { "type": "selector", "dimension": "type", "value": "Intent.Clean.succeeded" },
            { "type": "selector", "dimension": "type", "value": "QR.Result.actioned" },
            { "type": "selector", "dimension": "type", "value": "QR.Code.generated" },
            { "type": "selector", "dimension": "type", "value": "TelemetryDeck.Acquisition.newInstallDetected" }
          ]
        },
        "aggregations": [
          {
            "type": "filtered",
            "filter": {
              "type": "or",
              "fields": [
                { "type": "selector", "dimension": "type", "value": "Home.URL.copied" },
                { "type": "selector", "dimension": "type", "value": "Home.URL.shared" },
                { "type": "selector", "dimension": "type", "value": "Action.Clean.succeeded" },
                { "type": "selector", "dimension": "type", "value": "Action.Format.succeeded" },
                { "type": "selector", "dimension": "type", "value": "Intent.Clean.succeeded" },
                { "type": "selector", "dimension": "type", "value": "QR.Result.actioned" },
                { "type": "selector", "dimension": "type", "value": "QR.Code.generated" }
              ]
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_exporters",
              "fieldName": "clientUser"
            }
          },
          {
            "type": "filtered",
            "filter": {
              "type": "selector",
              "dimension": "type",
              "value": "TelemetryDeck.Acquisition.newInstallDetected"
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_installs",
              "fieldName": "clientUser"
            }
          }
        ],
        "postAggregations": [
          {
            "type": "arithmetic",
            "name": "activationRate",
            "fn": "/",
            "fields": [
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_exporters" },
                "name": "_exportersEstimate"
              },
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_installs" },
                "name": "_installsEstimate"
              }
            ]
          }
        ]
      }
    },
