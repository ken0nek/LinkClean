    "copyFormats.presets.footer" : {
      "comment" : "Footer under the format list explaining the free vs Pro split. 'Clean Link' and 'Markdown' are preset names shown in the same screen.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktive Formate erscheinen, wenn du einen Link kopierst. Ist nur eines aktiv, wird sofort kopiert; aktiviere mehrere, um jedes Mal zu wählen. Sauberer Link und Markdown sind kostenlos – Pro schaltet die übrigen und eigene Formate frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Active formats appear when you Copy link as…. One active copies instantly; activate several to pick each time. Clean Link and Markdown are free — Pro unlocks the rest and custom formats."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アクティブなフォーマットは「リンクをコピー」したときに表示されます。1つだけアクティブにすると即コピー、複数アクティブにすると毎回選べます。クリーンリンクとMarkdownは無料です。Proでその他とカスタムフォーマットが使えます。"
          }
        }
      }
    },
