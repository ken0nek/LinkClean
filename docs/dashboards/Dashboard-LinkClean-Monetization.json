{
  "title": "LinkClean — Monetization",
  "insights": [
    {
      "title": "Paywall impressions per day by trigger",
      "type": "customQuery",
      "displayMode": "lineChart",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 0,
      "customQuery": {
        "queryType": "groupBy",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "day",
        "dimensions": ["trigger"],
        "filter": {
          "type": "selector",
          "dimension": "type",
          "value": "Paywall.Screen.shown"
        },
        "aggregations": [
          {
            "type": "longSum",
            "name": "impressions",
            "fieldName": "count"
          }
        ]
      }
    },
    {
      "title": "Paywall click-through rate (view → purchase start, unique users)",
      "type": "customQuery",
      "displayMode": "bigNumber",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 1,
      "customQuery": {
        "queryType": "timeseries",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "all",
        "filter": {
          "type": "or",
          "fields": [
            { "type": "selector", "dimension": "type", "value": "Paywall.Screen.shown" },
            { "type": "selector", "dimension": "type", "value": "Paywall.Purchase.started" }
          ]
        },
        "aggregations": [
          {
            "type": "filtered",
            "filter": {
              "type": "selector",
              "dimension": "type",
              "value": "Paywall.Purchase.started"
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_clickers",
              "fieldName": "clientUser"
            }
          },
          {
            "type": "filtered",
            "filter": {
              "type": "selector",
              "dimension": "type",
              "value": "Paywall.Screen.shown"
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_viewers",
              "fieldName": "clientUser"
            }
          }
        ],
        "postAggregations": [
          {
            "type": "arithmetic",
            "name": "clickThroughRate",
            "fn": "/",
            "fields": [
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_clickers" },
                "name": "_clickersEstimate"
              },
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_viewers" },
                "name": "_viewersEstimate"
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Click-through rate by trigger (unique users) — which gate drives the click",
      "type": "customQuery",
      "displayMode": "barChart",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 2,
      "customQuery": {
        "queryType": "groupBy",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "all",
        "dimensions": ["trigger"],
        "filter": {
          "type": "or",
          "fields": [
            { "type": "selector", "dimension": "type", "value": "Paywall.Screen.shown" },
            { "type": "selector", "dimension": "type", "value": "Paywall.Purchase.started" }
          ]
        },
        "aggregations": [
          {
            "type": "filtered",
            "filter": {
              "type": "selector",
              "dimension": "type",
              "value": "Paywall.Purchase.started"
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_clickers",
              "fieldName": "clientUser"
            }
          },
          {
            "type": "filtered",
            "filter": {
              "type": "selector",
              "dimension": "type",
              "value": "Paywall.Screen.shown"
            },
            "aggregator": {
              "type": "thetaSketch",
              "name": "_viewers",
              "fieldName": "clientUser"
            }
          }
        ],
        "postAggregations": [
          {
            "type": "arithmetic",
            "name": "clickThroughRate",
            "fn": "/",
            "fields": [
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_clickers" },
                "name": "_clickersEstimate"
              },
              {
                "type": "thetaSketchEstimate",
                "field": { "type": "fieldAccess", "fieldName": "_viewers" },
                "name": "_viewersEstimate"
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Purchase starts per day by trigger",
      "type": "customQuery",
      "displayMode": "lineChart",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 3,
      "customQuery": {
        "queryType": "groupBy",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "day",
        "dimensions": ["trigger"],
        "filter": {
          "type": "selector",
          "dimension": "type",
          "value": "Paywall.Purchase.started"
        },
        "aggregations": [
          {
            "type": "longSum",
            "name": "starts",
            "fieldName": "count"
          }
