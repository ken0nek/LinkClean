      }
    },
    {
      "title": "Paywall dismissals per day by trigger (abandonment)",
      "type": "customQuery",
      "displayMode": "lineChart",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 4,
      "customQuery": {
        "queryType": "groupBy",
        "appID": "8A2AC88D-2092-43DC-BC71-CF675C33D01C",
        "baseFilters": "thisApp",
        "granularity": "day",
        "dimensions": ["trigger"],
        "filter": {
          "type": "selector",
          "dimension": "type",
          "value": "Paywall.Screen.dismissed"
