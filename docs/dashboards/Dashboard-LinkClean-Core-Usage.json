          "dimension": "type",
          "value": "TelemetryDeck.Session.started"
        },
        "aggregations": [
          {
            "type": "thetaSketch",
            "name": "_dauSketch",
            "fieldName": "clientUser"
          }
        ],
        "postAggregations": [
          {
            "type": "thetaSketchEstimate",
            "name": "dau",
            "field": {
              "type": "fieldAccess",
              "fieldName": "_dauSketch"
            }
          }
