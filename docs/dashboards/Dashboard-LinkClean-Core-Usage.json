    {
      "title": "URL-changed rate (Home cleans that altered the URL)",
      "type": "customQuery",
      "displayMode": "lineChart",
      "uniqueUser": false,
      "isExpanded": false,
      "groupBy": "day",
      "filters": {},
      "order": 10,
