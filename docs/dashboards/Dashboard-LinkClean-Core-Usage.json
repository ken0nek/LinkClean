        "granularity": "day",
        "filter": {
          "type": "selector",
          "dimension": "type",
          "value": "Home.URL.cleaned"
        },
        "aggregations": [
          {
            "type": "filtered",
            "filter": {
              "type": "and",
              "fields": [
                { "type": "selector", "dimension": "type", "value": "Home.URL.cleaned" },
                { "type": "selector", "dimension": "changed", "value": "true" }
              ]
            },
            "aggregator": {
